// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// NextAuth Next.js setup requires these models: Account, Session, User, VerificationToken
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("TPO") // 'ADMIN' or 'TPO'
  status        String    @default("PENDING") // 'PENDING', 'APPROVED', 'REJECTED'
  
  accounts      Account[]
  sessions      Session[]
  
  // TPO specific relations
  college       College?  @relation("TPOCollege")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// -------------------------------------------------------------
// Core Business Models
// -------------------------------------------------------------

model College {
  id              String   @id @default(cuid())
  name            String
  university      String
  departments     String   // Comma separated or JSON string
  partnershipType String   // e.g. 'CRT', 'FDP', 'External Placement Partner'
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tpoId           String   @unique
  tpo             User     @relation("TPOCollege", fields: [tpoId], references: [id])
  
  students        Student[]
  documents       Document[]
}

model Student {
  id            String   @id @default(cuid())
  name          String
  rollNumber    String   @unique
  department    String
  email         String?
  phone         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  collegeId     String
  college       College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  placements    Placement[]
  programs      StudentProgram[]
}

model Program {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  students    StudentProgram[]
}

model StudentProgram {
  id               String   @id @default(cuid())
  studentId        String
  programId        String
  status           String   @default("ENROLLED") // ENROLLED, COMPLETED, DROPPED
  progress         Int      @default(0) // percentage 0-100
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  program          Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([studentId, programId])
}

model Placement {
  id          String   @id @default(cuid())
  company     String
  ctc         Float?   // CTC in Lakhs (e.g., 46.0, 80.0)
  stipend     Float?   // Internship stipend in thousands
  role        String?
  year        String   // Academic year e.g. "2024-25"
  dateOffered DateTime?
  createdAt   DateTime @default(now())

  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Document {
  id          String   @id @default(cuid())
  name        String
  url         String   // URL or local path
  type        String   // 'MOU', 'PARTNERSHIP_AGREEMENT', etc.
  expiryDate  DateTime?
  createdAt   DateTime @default(now())

  collegeId   String
  college     College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
}
